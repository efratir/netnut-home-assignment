generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum JobStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

model Job {
  id        String    @id @default(uuid())
  url       String
  status    JobStatus @default(PENDING)
  // In production this would be an S3/MinIO object key, not inline text
  html      String?
  error     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}
